# YouTube Data API v3
YOUTUBE_API_KEY=AIzaSyBQxROmk6aLxvdLjA6pNT_AftIXtEnlFXY
YOUTUBE_CHANNEL_ID=UC9WNQ1AUrjOle0QihbaSLdw

# ============================================
# Cloudflare Configuration
# ============================================

# D1 Database
DATABASE_ID=your-d1-database-id
DATABASE_NAME=english-portfolio

# R2 Storage
R2_BUCKET_NAME=english-portfolio-assets
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_PUBLIC_URL=https://your-cdn.example.com

# ============================================
# Application Configuration
# ============================================

# Site Settings
SITE_URL=https://yourdomain.com
SITE_TITLE=English Teacher Portfolio
SITE_DESCRIPTION=Professional English teaching platform with courses, blog, and resources

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ============================================
# Authentication & Security
# ============================================

# JWT Secret for session tokens (change in production!)
JWT_SECRET=your-super-secret-key-change-this-in-production

# Admin Email (for notifications)
ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# Third-party Integrations
# ============================================

# Email Service (optional, for contact form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SendGrid (alternative to SMTP)
SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================
# Analytics (optional)
# ============================================

NEXT_PUBLIC_GA_ID=your-google-analytics-id

# ============================================
# Feature Flags
# ============================================

# Enable/disable features
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_RATINGS=true
NEXT_PUBLIC_ENABLE_SOCIAL_SHARING=true
